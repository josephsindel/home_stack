{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Logs / Explorer",
  "uid": "vlogs-explorer",
  "tags": ["logs", "victorialogs"],
  "timezone": "",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "query",
        "type": "textbox",
        "label": "LogsQL",
        "current": { "text": "*", "value": "*" },
        "query": "*"
      }
    ]
  },
  "panels": [
    {
      "title": "Log volume",
      "type": "timeseries",
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "$query",
          "queryType": "hits"
        }
      ]
    },
    {
      "title": "Logs",
      "type": "logs",
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 7 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "$query",
          "queryType": "instant",
          "maxLines": 1000
        }
      ]
    }
  ]
}
