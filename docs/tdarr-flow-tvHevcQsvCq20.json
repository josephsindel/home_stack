        {
            "name": "Keep original (compat remux suspicious)",
            "sourceRepo": "Community",
            "pluginName": "failFlow",
            "version": "1.0.0",
            "id": "compatFail",
            "position": {
                "x": 240,
                "y": 1020
            }
        },
        {
            "name": "Prefer AAC stereo default",
            "sourceRepo": "Community",
            "pluginName": "customFunction",
            "version": "1.0.0",
            "id": "preferAacDefault",
            "position": {
                "x": 500,
                "y": 420
            },
            "inputsDB": {
                "code": "module.exports = async (args) => {\n  const streams = args.variables.ffmpegCommand.streams || [];\n  const isAudio = (stream) => stream.codec_type === 'audio';\n  const isVideo = (stream) => stream.codec_type === 'video';\n  const outputArgs = (stream) => Array.isArray(stream.outputArgs) ? stream.outputArgs : [];\n  const willEncodeAacStereo = (stream) => {\n    const argsOut = outputArgs(stream);\n    const hasAacEncoder = argsOut.includes('aac');\n    const acIndex = argsOut.indexOf('-ac');\n    return hasAacEncoder && acIndex !== -1 && String(argsOut[acIndex + 1]) === '2';\n  };\n  const isExistingAacStereo = (stream) => stream.codec_name === 'aac' && Number(stream.channels) === 2;\n  const preferred = streams.find((stream) => isAudio(stream) && (willEncodeAacStereo(stream) || isExistingAacStereo(stream)));\n\n  if (!preferred) {\n    args.jobLog('No AAC stereo stream available to make default.');\n    return { outputFileObj: args.inputFileObj, outputNumber: 1, variables: args.variables };\n  }\n\n  const withoutPreferred = streams.filter((stream) => stream !== preferred);\n  const sorted = [\n    ...withoutPreferred.filter(isVideo),\n    preferred,\n    ...withoutPreferred.filter((stream) => isAudio(stream)),\n    ...withoutPreferred.filter((stream) => !isVideo(stream) && !isAudio(stream)),\n  ];\n\n  const stripDispositionArgs = (stream) => {\n    const argsOut = outputArgs(stream);\n    const cleaned = [];\n    for (let i = 0; i < argsOut.length; i += 1) {\n      if (String(argsOut[i]).startsWith('-disposition')) {\n        i += 1;\n      } else {\n        cleaned.push(argsOut[i]);\n      }\n    }\n    stream.outputArgs = cleaned;\n  };\n\n  for (const stream of sorted) {\n    stripDispositionArgs(stream);\n  }\n\n  let audioIndex = 0;\n  for (const stream of sorted) {\n    if (isAudio(stream)) {\n      stream.outputArgs.push('-disposition:a:{outputTypeIndex}', audioIndex === 0 ? 'default' : '0');\n      audioIndex += 1;\n    }\n  }\n\n  args.variables.ffmpegCommand.streams = sorted;\n  args.variables.ffmpegCommand.shouldProcess = true;\n  args.jobLog('AAC stereo is ordered first and marked as the default audio stream.');\n\n  return { outputFileObj: args.inputFileObj, outputNumber: 1, variables: args.variables };\n};"
            }
        }
    ],
