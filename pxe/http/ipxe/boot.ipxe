#!ipxe
echo
echo === Talos netboot :: mac=${mac} ip=${ip} ===
echo
set base http://192.168.87.53:8080
kernel ${base}/boot/v1.13.2/kernel-amd64 talos.platform=metal console=tty0 console=ttyS0,115200n8 init_on_alloc=1 slab_nomerge pti=on consoleblank=0 nvme_core.io_timeout=4294967295 printk.devkmsg=on selinux=1 module.sig_enforce=1 proc_mem.force_override=never
initrd ${base}/boot/v1.13.2/initramfs-amd64.xz
boot
